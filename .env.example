# WhatsApp — bouton "Demander sur WhatsApp" sur la carte produit
# Numéro business au format international SANS + ni espaces (ex: 2250700000000).
# Laissé vide, le lien wa.me ouvre le sélecteur de contact.
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Better Auth
BETTER_AUTH_SECRET=          # Generate: openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:8788
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:8788

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — Facebook
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# OAuth — Apple
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Email — Resend
RESEND_API_KEY=            # Clé API depuis resend.com/api-keys
RESEND_FROM_EMAIL=DBS Store <noreply@dbs-store.ci>

# Cloudflare R2 — upload images (bannières, produits, avatars)
# Aucune variable d'env requise : on utilise le binding R2 "MEDIA"
# (wrangler.jsonc). En dev, miniflare simule le bucket localement.

# Note: DATABASE_URL n'est plus utilisé.
# La base D1 est configurée dans wrangler.jsonc.
# Pour le dev local: wrangler dev (port 8788 par défaut)
# Pour les secrets en prod: wrangler secret put BETTER_AUTH_SECRET
